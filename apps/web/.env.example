NODE_ENV=development
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000
STORE_ADAPTER=memory
DATABASE_URL=postgres://postgres:postgres@localhost:5432/binhminh
CONSENT_POLICY_VERSION=policy-2026-03-01
RATE_LIMIT_BOOKING_PER_MINUTE=20
IDEMPOTENCY_TTL_SECONDS=86400
OUTBOX_BATCH_SIZE=20
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_BASE_DELAY_SECONDS=15
WORKER_DISPATCH_TOKEN=change-this-token
OPS_METRICS_TOKEN=change-this-token
OUTBOX_DISPATCH_URL=http://localhost:3000/api/internal/queue/dispatch
IDEMPOTENCY_RETENTION_DAYS=2
OUTBOX_DONE_RETENTION_DAYS=7
OUTBOX_FAILED_RETENTION_DAYS=30
HEALTH_OUTBOX_FAILED_MAX=10
HEALTH_OUTBOX_PENDING_MAX=500
OPS_ALERT_OUTBOX_FAILED_CRITICAL=5
OPS_ALERT_OUTBOX_PENDING_WARNING=100
OPS_ALERT_OUTBOX_PENDING_CRITICAL=300
OPS_ALERT_IDEMPOTENCY_IN_PROGRESS_CRITICAL=20

# UPSTASH REDIS
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

